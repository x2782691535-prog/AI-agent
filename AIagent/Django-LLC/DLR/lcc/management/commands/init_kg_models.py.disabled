"""
初始化知识图谱数据模型
"""

from django.core.management.base import BaseCommand
from django.db import transaction
from lcc.models import EntityType, RelationType


class Command(BaseCommand):
    help = '初始化知识图谱的实体类型和关系类型'

    def add_arguments(self, parser):
        parser.add_argument(
            '--reset',
            action='store_true',
            help='重置所有类型定义',
        )

    def handle(self, *args, **options):
        if options['reset']:
            self.stdout.write('正在重置类型定义...')
            EntityType.objects.all().delete()
            RelationType.objects.all().delete()

        with transaction.atomic():
            self.create_entity_types()
            self.create_relation_types()

        self.stdout.write(
            self.style.SUCCESS('知识图谱数据模型初始化完成！')
        )

    def create_entity_types(self):
        """创建实体类型"""
        self.stdout.write('创建实体类型...')
        
        entity_types = [
            # 基础类型
            {
                'name': 'PERSON',
                'label': '人物',
                'description': '个人、人物实体',
                'category': 'basic',
                'color': '#ff9999',
                'icon': 'fa-user',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]{2,4}(?:先生|女士|教授|博士|工程师|经理|主任)',
                    r'[\u4e00-\u9fff]{2,4}(?:院士|专家|学者|研究员)'
                ]
            },
            {
                'name': 'ORGANIZATION',
                'label': '组织机构',
                'description': '公司、机构、组织实体',
                'category': 'basic',
                'color': '#99ccff',
                'icon': 'fa-building',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]+(?:公司|企业|集团|有限公司|股份公司)',
                    r'[\u4e00-\u9fff]+(?:大学|学院|研究所|实验室|中心)'
                ]
            },
            {
                'name': 'LOCATION',
                'label': '地理位置',
                'description': '地点、位置实体',
                'category': 'basic',
                'color': '#ffcc99',
                'icon': 'fa-map-marker',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]+(?:省|市|县|区|镇|村)',
                    r'[\u4e00-\u9fff]+(?:国|州|洲)'
                ]
            },
            {
                'name': 'CONCEPT',
                'label': '概念术语',
                'description': '概念、术语、技术实体',
                'category': 'basic',
                'color': '#99ff99',
                'icon': 'fa-lightbulb-o',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]{2,8}(?:技术|方法|理论|算法|模型)',
                    r'[\u4e00-\u9fff]{2,8}(?:系统|平台|框架|协议)'
                ]
            },
            {
                'name': 'PRODUCT',
                'label': '产品服务',
                'description': '产品、服务、商品实体',
                'category': 'basic',
                'color': '#ff99ff',
                'icon': 'fa-cube',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]+(?:产品|服务|软件|硬件|设备)',
                    r'[\u4e00-\u9fff]+(?:系统|平台|工具|应用)'
                ]
            },
            {
                'name': 'EVENT',
                'label': '事件活动',
                'description': '事件、活动、会议实体',
                'category': 'basic',
                'color': '#ccff99',
                'icon': 'fa-calendar',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]+(?:会议|大会|论坛|峰会|活动)',
                    r'[\u4e00-\u9fff]+(?:发布会|展览|比赛|竞赛)'
                ]
            },
            {
                'name': 'TIME',
                'label': '时间',
                'description': '时间、日期实体',
                'category': 'basic',
                'color': '#ffccff',
                'icon': 'fa-clock-o',
                'extraction_patterns': [
                    r'\d{4}年\d{1,2}月\d{1,2}日',
                    r'\d{4}-\d{1,2}-\d{1,2}'
                ]
            },
            {
                'name': 'DOCUMENT',
                'label': '文档',
                'description': '文档、文件实体',
                'category': 'basic',
                'color': '#ccccff',
                'icon': 'fa-file-text',
                'extraction_patterns': [
                    r'[\u4e00-\u9fff]+\.(?:pdf|doc|docx|txt|html)',
                    r'《[\u4e00-\u9fff]+》'
                ]
            },
        ]

        for entity_data in entity_types:
            entity_type, created = EntityType.objects.get_or_create(
                name=entity_data['name'],
                defaults=entity_data
            )
            if created:
                self.stdout.write(f'  ✅ 创建实体类型: {entity_type.label}')
            else:
                self.stdout.write(f'  ⚠️ 实体类型已存在: {entity_type.label}')

    def create_relation_types(self):
        """创建关系类型"""
        self.stdout.write('创建关系类型...')
        
        relation_types = [
            # 基础关系
            {
                'name': 'IS_A',
                'label': '是一个',
                'description': '上下位关系，表示类别归属',
                'category': 'semantic',
                'extraction_patterns': [
                    r'(.+?)是(.+?)的',
                    r'(.+?)属于(.+)',
                    r'(.+?)是一种(.+)'
                ]
            },
            {
                'name': 'PART_OF',
                'label': '属于',
                'description': '部分整体关系',
                'category': 'semantic',
                'extraction_patterns': [
                    r'(.+?)包含(.+)',
                    r'(.+?)由(.+?)组成',
                    r'(.+?)的组成部分是(.+)'
                ]
            },
            {
                'name': 'RELATED_TO',
                'label': '相关',
                'description': '一般相关关系',
                'category': 'semantic',
                'extraction_patterns': [
                    r'(.+?)与(.+?)相关',
                    r'(.+?)和(.+?)有关'
                ]
            },
            
            # 人物关系
            {
                'name': 'WORKS_FOR',
                'label': '工作于',
                'description': '工作关系',
                'category': 'social',
                'extraction_patterns': [
                    r'(.+?)在(.+?)工作',
                    r'(.+?)任职于(.+)',
                    r'(.+?)是(.+?)的员工'
                ]
            },
            {
                'name': 'STUDIES_AT',
                'label': '学习于',
                'description': '学习关系',
                'category': 'social',
                'extraction_patterns': [
                    r'(.+?)在(.+?)学习',
                    r'(.+?)就读于(.+)'
                ]
            },
            {
                'name': 'KNOWS',
                'label': '认识',
                'description': '认识关系',
                'category': 'social',
                'is_symmetric': True,
                'extraction_patterns': [
                    r'(.+?)认识(.+)',
                    r'(.+?)和(.+?)是朋友'
                ]
            },
            
            # 地理关系
            {
                'name': 'LOCATED_IN',
                'label': '位于',
                'description': '地理位置关系',
                'category': 'spatial',
                'extraction_patterns': [
                    r'(.+?)位于(.+)',
                    r'(.+?)在(.+?)地区',
                    r'(.+?)坐落在(.+)'
                ]
            },
            {
                'name': 'CONTAINS',
                'label': '包含',
                'description': '地理包含关系',
                'category': 'spatial',
                'extraction_patterns': [
                    r'(.+?)包括(.+)',
                    r'(.+?)下辖(.+)'
                ]
            },
            
            # 时间关系
            {
                'name': 'OCCURS_AT',
                'label': '发生于',
                'description': '时间发生关系',
                'category': 'temporal',
                'extraction_patterns': [
                    r'(.+?)发生在(.+)',
                    r'(.+?)于(.+?)举行'
                ]
            },
            {
                'name': 'BEFORE',
                'label': '之前',
                'description': '时间先后关系',
                'category': 'temporal',
                'extraction_patterns': [
                    r'(.+?)在(.+?)之前',
                    r'(.+?)早于(.+)'
                ]
            },
            {
                'name': 'AFTER',
                'label': '之后',
                'description': '时间后续关系',
                'category': 'temporal',
                'extraction_patterns': [
                    r'(.+?)在(.+?)之后',
                    r'(.+?)晚于(.+)'
                ]
            },
            
            # 业务关系
            {
                'name': 'PRODUCES',
                'label': '生产',
                'description': '生产制造关系',
                'category': 'domain',
                'extraction_patterns': [
                    r'(.+?)生产(.+)',
                    r'(.+?)制造(.+)',
                    r'(.+?)开发(.+)'
                ]
            },
            {
                'name': 'USES',
                'label': '使用',
                'description': '使用关系',
                'category': 'domain',
                'extraction_patterns': [
                    r'(.+?)使用(.+)',
                    r'(.+?)采用(.+)',
                    r'(.+?)应用(.+)'
                ]
            },
            {
                'name': 'CAUSES',
                'label': '导致',
                'description': '因果关系',
                'category': 'semantic',
                'extraction_patterns': [
                    r'(.+?)导致(.+)',
                    r'(.+?)引起(.+)',
                    r'(.+?)造成(.+)'
                ]
            },
        ]

        for relation_data in relation_types:
            relation_type, created = RelationType.objects.get_or_create(
                name=relation_data['name'],
                defaults=relation_data
            )
            if created:
                self.stdout.write(f'  ✅ 创建关系类型: {relation_type.label}')
            else:
                self.stdout.write(f'  ⚠️ 关系类型已存在: {relation_type.label}')
